# Web-target overrides. Loaded by Vite on top of .env when running with
# `--mode web` (see the `web:*` scripts in package.json). Only contains
# the bit that needs to differ between targets — VITE_SUPABASE_URL and
# VITE_SUPABASE_ANON_KEY are shared between both builds and stay in .env.
#
# VITE_APP_VERSION is set at build time by vite.web.config.mjs's `define`
# block (from package.json#version), so it isn't repeated here.

VITE_TARGET=web
